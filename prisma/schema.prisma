generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   Profile?
  plans     Plan[]
  allergies UserAllergy[]
}

model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique
  heightCm          Float?
  weightKg          Float?
  age               Int?
  gender            String?
  occupation        String?
  city              String?
  activityLevel     String?   // Active | Sedentary | Moderately Active
  physicalActivity  Boolean?
  activityFrequency String?   // times per week
  mealsPerDay       String?
  nutritionalGoal   String?   // Weight loss | Muscle gain | Energy maintenance
  dietaryPreference String?   // Healthy recipes | Modern | Traditional
  recipeLikes       String?
  recipeDislikes    String?
  chronicDisease    String?
  medication        String?
  otherSymptoms     String?
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Recipe {
  id           String   @id @default(cuid())
  name         String   @unique
  nameAr       String?
  ingredients  String   // comma-separated ingredient string from xlsx
  category     String?
  createdAt    DateTime @default(now())

  recipeIngredients RecipeIngredient[]
  planTasks         Task[]
}

model Ingredient {
  id        String   @id @default(cuid())
  name      String   @unique
  allergyId String?
  createdAt DateTime @default(now())

  allergy           Allergy?           @relation(fields: [allergyId], references: [id])
  recipeIngredients RecipeIngredient[]
}

model RecipeIngredient {
  id           String @id @default(cuid())
  recipeId     String
  ingredientId String

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([recipeId, ingredientId])
}

model Allergy {
  id   String @id @default(cuid())
  name String @unique

  ingredients  Ingredient[]
  userAllergies UserAllergy[]
  crossAllergies CrossAllergy[] @relation("CrossAllergyFrom")
}

model CrossAllergy {
  id          String @id @default(cuid())
  ingredient1 String
  ingredient2 String
  allergyId   String

  allergy Allergy @relation("CrossAllergyFrom", fields: [allergyId], references: [id])

  @@unique([ingredient1, ingredient2])
}

model UserAllergy {
  userId    String
  allergyId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  allergy Allergy @relation(fields: [allergyId], references: [id], onDelete: Cascade)

  @@id([userId, allergyId])
}

model Plan {
  id              String   @id @default(cuid())
  userId          String
  goalType        String
  goalDetails     String
  durationDays    Int
  startDate       DateTime
  endDate         DateTime
  status          String   @default("active") // active | completed | cancelled
  planSummary     String?
  dailyCalorieTarget Int?
  dailyProteinTarget Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]
}

model Task {
  id           String    @id @default(cuid())
  planId       String
  dayNumber    Int
  date         DateTime
  category     String    // nutrition | exercise | hydration | sleep | mindfulness
  title        String
  description  String
  recipeId     String?
  completed    Boolean   @default(false)
  completedAt  DateTime?
  caloriesKcal Int?
  durationMin  Int?
  createdAt    DateTime  @default(now())

  plan   Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  recipe Recipe? @relation(fields: [recipeId], references: [id])
}
